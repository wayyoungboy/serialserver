<Window x:Class="VSPManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VSP Manager - 虚拟串口管理器" Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid Margin="15">
        <!-- Login Page -->
        <Grid x:Name="LoginGrid" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="VSP Manager" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <GroupBox Grid.Row="1" Header="服务器设置" Padding="15">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="服务器:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding ServerHost}" Padding="5" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="端口:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="3" Text="{Binding ServerPort}" Padding="5"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="用户登录" Padding="15">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="用户名:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" Text="{Binding Username}" Padding="5"/>
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="密码:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <PasswordBox x:Name="PasswordBox" Grid.Column="1" Padding="5"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="登录" Command="{Binding LoginCommand}"
                                Style="{StaticResource PrimaryButton}" MinWidth="100" Margin="0,0,10,0"/>
                        <Button Content="退出" Click="OnExitClick"
                                Style="{StaticResource PrimaryButton}" MinWidth="100"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" HorizontalAlignment="Center" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Main Page -->
        <Grid x:Name="MainGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="VSP Manager" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding CurrentUser, StringFormat='用户: {0}'}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="退出登录" Command="{Binding LogoutCommand}" Padding="10,5"/>
                </StackPanel>
            </Grid>

            <!-- Device List -->
            <GroupBox Grid.Row="1" Header="我的设备" Padding="10">
                <ListView ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                          Height="150" SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="设备名称" DisplayMemberBinding="{Binding Name}" Width="150"/>
                            <GridViewColumn Header="串口" DisplayMemberBinding="{Binding SerialPort}" Width="80"/>
                            <GridViewColumn Header="波特率" DisplayMemberBinding="{Binding BaudRate}" Width="80"/>
                            <GridViewColumn Header="状态" DisplayMemberBinding="{Binding Status}" Width="80"/>
                            <GridViewColumn Header="Device Key" DisplayMemberBinding="{Binding DeviceKey}" Width="150"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Connection Settings -->
            <GroupBox Grid.Row="2" Header="连接设置" Padding="10" Margin="0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="虚拟串口:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PortName}" Padding="5" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="状态:" VerticalAlignment="Center" Margin="10,0,10,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0,0,0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="接收:" VerticalAlignment="Center" Margin="0,5,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BytesReceived, StringFormat='{}{0:N0} 字节'}" VerticalAlignment="Center" Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="发送:" VerticalAlignment="Center" Margin="10,5,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BytesSent, StringFormat='{}{0:N0} 字节'}" VerticalAlignment="Center" Margin="0,5,0,0"/>
                </Grid>
            </GroupBox>

            <!-- Actions -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button Content="启动远程串口" Command="{Binding ConnectCommand}"
                        IsEnabled="{Binding CanConnect}" Style="{StaticResource PrimaryButton}" MinWidth="120" Margin="0,0,10,0"/>
                <Button Content="停止" Command="{Binding DisconnectCommand}"
                        IsEnabled="{Binding CanDisconnect}" Style="{StaticResource PrimaryButton}" MinWidth="100" Margin="0,0,10,0"/>
                <Button Content="保存配置" Command="{Binding SaveConfigCommand}"
                        Style="{StaticResource PrimaryButton}" MinWidth="100"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>